# ─────────────────────────────────────────────────────────
# 루트 빌드 컨텍스트용 (frontend 이미지 빌드 = context: .)
# frontend 이미지는 @synapse/shared(../shared) 참조 때문에
# 레포 루트를 컨텍스트로 사용한다. 시크릿·불필요 파일 차단.
# ─────────────────────────────────────────────────────────

# 시크릿 (절대 이미지에 들어가면 안 됨)
**/.env
**/.env.*
!**/.env.example
*.pem
*.key

# VCS / 에디터
.git
.gitignore
.vscode
.idea

# Node
**/node_modules
**/dist

# Python (frontend 빌드엔 불필요)
**/.venv
**/__pycache__
**/*.py[cod]
**/.ruff_cache
**/.pytest_cache
**/.mypy_cache

# 빌드에 불필요한 디렉토리/파일 (frontend 이미지 기준)
backend
extension
nginx
docs
.github
docker-compose*.yml
docker-compose*.yaml
*.md
