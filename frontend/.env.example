# 로컬 dev (pnpm dev + docker-compose.dev.yml 백엔드)
VITE_API_BASE_URL=http://localhost:8000

# 배포·통합 테스트 (docker compose up + nginx, 로컬)
# VITE_API_BASE_URL=http://localhost

# 배포·EC2 (실제 도메인 — 프론트 빌드 시 박힘, compose build 전에 설정)
# VITE_API_BASE_URL=https://your-domain.com

# ※ Google Drive 폴더 연동(Picker)의 client_id / picker API key는
#    프론트 빌드에 박지 않고 백엔드 env(GOOGLE_CLIENT_ID / GOOGLE_PICKER_API_KEY)에서
#    GET /api/v1/auth/google-config 로 받아온다. 여기엔 둘 필요 없음.
