# 로컬 dev (pnpm dev + docker-compose.dev.yml 백엔드)
VITE_API_BASE_URL=http://localhost:8000

# 배포·통합 테스트 (docker compose up + nginx, 로컬)
# VITE_API_BASE_URL=http://localhost

# 배포·EC2 (실제 도메인 — 프론트 빌드 시 박힘, compose build 전에 설정)
# VITE_API_BASE_URL=https://your-domain.com

# ── Google Drive 폴더 연동 (Picker) ──────────────
# 브라우저 공개 안전 값 — origin/referrer 제한으로 보호 (비밀 아님).
# client_id: OAuth Web 클라이언트 (승인된 JS 원본에 도메인 등록 필요)
# api_key:   Google Picker API 사용설정된 키 (referrer 제한 권장)
VITE_GOOGLE_CLIENT_ID=533932065642-uv3rvkm11idqk67vb4jdub51vu31jck1.apps.googleusercontent.com
VITE_GOOGLE_PICKER_API_KEY=
