# ============================================
# Synapse Platform — local secrets
# ============================================
# backend 폴더에서: copy .env.example .env

# ── Database (PostgreSQL + pgvector) ─────────
# 로컬
DATABASE_URL=
# 배포 (docker-compose·EC2 — compose 서비스명 db)
# DATABASE_URL=

# ── Profiler (Google AI) ─────────────────────
# 키 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Navigator (OpenAI) ───────────────────────
OPENAI_API_KEY=

# ── Groq (LLM) ─────────────────────────────
GROQ_API_KEY=

# ── YouTube (재생목록) ───────────────────────
YOUTUBE_API_KEY=

# ── Resend (분석 완료 메일) ──────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Synapse <synapse@ifive.site>


# ── Naver (검색) ─────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Google (OAuth) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ── 공통 ────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000