# ============================================
# Synapse Profiler — local secrets
# ============================================
#
# 1) backend 폴더에서 복사:
#      copy .env.example .env
# 2) 아래 GOOGLE_API_KEY 에 키만 붙여넣기
#
# 키 발급: https://aistudio.google.com/apikey
# 키를 비우면 Layer A는 규칙 기반 fallback 으로 동작합니다.
# ============================================

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Resend — 분석 완료 메일 (notify 노드)
# 키 발급: https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Synapse <synapse@ifive.site>

# 메일 본문 프로필 링크 (선택)
FRONTEND_BASE_URL=http://localhost:3000
