
# ============================================
# Synapse Platform — local secrets
# ============================================
# backend 폴더에서: copy .env.example .env

# ── Database (PostgreSQL + pgvector) ─────────
# 로컬
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synapse
# 배포 (docker-compose·EC2 — compose 서비스명 db)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/synapse

# ── Profiler (Google AI) ─────────────────────
# 키 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Navigator (OpenAI) ───────────────────────
OPENAI_API_KEY=

# ── YouTube (재생목록) ───────────────────────
YOUTUBE_API_KEY=

# ── Resend (분석 완료 메일) ──────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Synapse <synapse@ifive.site>


# ── Naver (검색) ─────────────────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Google (OAuth) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PICKER_API_KEY=

# ── 공통 ────────────────────────────────────
# JWT access token (프론트 메모리) + refresh token (httpOnly 쿠키·DB)
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
# 배포 HTTPS 시 true
COOKIE_SECURE=false


# 로컬 pnpm dev
FRONTEND_BASE_URL=http://localhost:5173

# 배포·통합 테스트 (docker compose up + nginx, 로컬)
# FRONTEND_BASE_URL=http://localhost

# 배포·EC2 (실제 도메인 — OAuth 리다이렉트·완료 메일 링크)
# FRONTEND_BASE_URL=https://your-domain.com
