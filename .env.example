# ─────────────────────────────────────────────────────────
# Synapse 배포용 .env 예시  (EC2: ~/synapse/.env)
#
# docker-compose.yaml이 읽는 런타임 환경변수. 실제 .env는
# CD(GitHub Actions)가 GitHub Secrets로부터 자동 생성한다.
# 수동 배포/통합테스트 시: `cp .env.example .env` 후 값 채우기.
#
# ⚠️ .env 는 절대 커밋 금지 (.gitignore 처리됨). 이 예시만 커밋.
# ─────────────────────────────────────────────────────────

# ── 이미지 (Docker Hub) ───────────────────────────────────
DOCKER_HUB_USERNAME=your-dockerhub-username
IMAGE_TAG=latest                      # CD는 커밋 SHA로 덮어씀

# ── DB ───────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-random-32+

# ── 인증 (JWT 서명키 — 운영에선 반드시 교체) ──────────────
JWT_SECRET_KEY=change-me-random-48chars

# ── 외부 API 키 ──────────────────────────────────────────
OPENAI_API_KEY=
GOOGLE_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

YOUTUBE_API_KEY=

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────
# 아래는 docker-compose.yaml이 직접 설정하므로 .env에 불필요:
#   DATABASE_URL      (postgres:${POSTGRES_PASSWORD}@db:5432/synapse)
#   FRONTEND_BASE_URL (https://ifive.site)
#   COOKIE_SECURE     (true)
# 프론트 VITE_API_BASE_URL 은 이미지 빌드 시 주입(cd.yml), 런타임 무관.
# ─────────────────────────────────────────────────────────
