# ============================================
# Synapse Platform — production secrets (EC2)
# ============================================
# compose.prod.yml 옆 .env 로 사용.
# 이 파일 내용을 채워 GitHub 시크릿 EC2_ENV_FILE 에 통째로 넣으면
# CD(SSH)가 배포 시 EC2에 .env 로 써넣음. (실제 .env는 커밋 금지)
# Docker Hub username/태그는 compose.prod.yml + CD 셸 변수로 주입됨(여기 없음).

# ── Database (PostgreSQL + pgvector) ─────────
# compose의 db 컨테이너가 이 값으로 초기화됨 (호스트는 서비스명 db)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=synapse
# 비밀번호는 위 POSTGRES_PASSWORD와 반드시 동일하게
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-password@db:5432/synapse

# ── Profiler (Google AI) ─────────────────────
# 키 발급: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Navigator (OpenAI) ───────────────────────
OPENAI_API_KEY=

# ── YouTube (급상승·재생목록) ─────────────────
# Google Cloud Console → APIs & Services → YouTube Data API v3 활성화 필요
YOUTUBE_API_KEY=

# ── Resend (분석 완료 메일) ──────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Synapse <synapse@ifive.site>

# ── Naver (검색·뉴스 Open API) ────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── Google (OAuth) ─────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# prod redirect — Google 콘솔에도 동일하게 등록해야 로그인 됨
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/callback

# ── 공통 ────────────────────────────────────
# JWT access token (프론트 메모리) + refresh token (httpOnly 쿠키·DB)
# 생성: openssl rand -hex 32  (dev 기본값 쓰지 말 것)
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# 배포 HTTPS 시 true (필수 — 안 하면 로그인 세션 안 붙음).
# TLS 미설정(http)으로 임시 테스트할 땐 false 로.
COOKIE_SECURE=true

# 배포·EC2 (실제 도메인 — OAuth 리다이렉트·완료 메일 링크)
FRONTEND_BASE_URL=https://your-domain.com
